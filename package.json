{
  "name": "@mgfujikura/vue-components",
  "private": false,
  "version": "0.6.0",
  "type": "module",
  "types": "./types/lib.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "exports": {
    ".": {
      "types": "./types/lib.d.ts",
      "import": "./dist/fw-vue-components.js"
    },
    "./css": "./dist/style.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:mgfujikura/vue-components"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "check": "pnpm lint:check && pnpm test:run && pnpm build",
    "test": "vitest --project unit",
    "test:run": "vitest run --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:storybook": "vitest run --project storybook",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "remeda": "^2.33.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.8",
    "vue": "^3.5.27",
    "vue-tsc": "^3.3.4",
    "storybook": "^10.4.4",
    "@storybook/vue3-vite": "^10.4.4",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-onboarding": "^10.4.4",
    "eslint-plugin-storybook": "^10.4.4",
    "playwright": "^1.60.0",
    "@vitest/browser-playwright": "4.1.8"
  }
}
